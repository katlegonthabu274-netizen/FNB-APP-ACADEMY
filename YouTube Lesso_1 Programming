#Applying methods to strings
course = "Python for Beginners"
 #        0123456789
print(course.upper())#This is used to convert a string into uppercase letters 
print(course.lower()) #This is used to convert a string into lowercase letters
print(course.title()) #This is used to capitalize the first letter of each word in a string       
print(course.strip()) #This is used to remove any whitespace from the beginning or end of a string  
print(course.find("P")) #This is used to find the index of a character in a string
print(course.replace("for", "4")) #This is used to replace a character in a string with another character   
print(course.find('Python')) #This is used to find the index of a substring in a string
print('Python' in course) #This is used to check if a substring is present in a string and returns a boolean value          

